# --- Routing -----------------------------------------------------------------
# Subdomain Traefik will route to the web app (no protocol, no trailing slash)
DOMAIN=2048.example.com

# --- Telegram ----------------------------------------------------------------
# Token from @BotFather
BOT_TOKEN=

# Public https URL of the Mini App. Telegram requires https.
# Normally the same as https://${DOMAIN}
WEB_APP_URL=https://2048.example.com

# --- Database ----------------------------------------------------------------
# Postgres connection string, consumed by the bot service.
# Leave empty if not used yet — the bot will start without it.
DATABASE_URL=
